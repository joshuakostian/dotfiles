theme = lackluster
window-padding-x = 30
window-padding-y = 10

background-opacity = .9
background-blur = true

macos-icon = "retro"

font-family = "Iosevka SS15"
font-family = "Iosevka Nerd Font Mono"
font-size = 20

adjust-underline-position = 20%
adjust-underline-thickness = 10%

cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

custom-shader = ~/.config/ghostty/shaders/in-game-crt-cursor.glsl
